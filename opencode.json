{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "openagent",
  "plugin": ["./plugins/ponytail.mjs"],
  "provider": {
    "groq": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Groq",
      "options": {
        "baseURL": "https://api.groq.com/openai/v1",
        "apiKey": "{env:GROQ_API_KEY}"
      },
      "models": {
        "meta-llama/llama-4-scout-17b-16e-instruct": {
          "name": "Llama 4 Scout"
        }
      }
    }
  },
  "instructions": [
    "AGENTS.md",
    "SOUL.md",
    ".opencode/WORKING-CONTEXT.md"
  ],
  "permission": {
    "bash": {
    "*": "allow"},
    "edit": "allow",
    "write": "allow",
    "read": "allow",
    "delete": "allow"

  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp@latest"],
      "enabled": true,
      "env": {
        "DEFAULT_MINIMUM_TOKENS": "5000"
      }
    },
    "github-mcp-server": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "enabled": true,
      "env": {
        "GITHUB_TOKEN": "{env:GITHUB_TOKEN}"
      }
    },
    "mssql": {
      "type": "local",
      "command": ["npx", "-y", "mssql-mcp@latest"],
      "enabled": true,
      "env": {
        "MSSQL_HOST": "{env:MSSQL_HOST}",
        "MSSQL_PORT": "{env:MSSQL_PORT}",
        "MSSQL_USER": "{env:MSSQL_USER}",
        "MSSQL_PASSWORD": "{env:MSSQL_PASSWORD}",
        "MSSQL_DATABASE": "{env:MSSQL_DATABASE}"
      }
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": false
    },
    "awesome-copilot": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "Logging__LogLevel__Default=Error",
        "ghcr.io/microsoft/mcp-dotnet-samples/awesome-copilot:latest"
      ],
      "enabled": true
    },
    "mongodb-mcp-server": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mongodb-mcp-server"
      ],
      "enabled": false,
      "env": {
        "MDB_MCP_CONNECTION_STRING": "{env:MONGODB_CONNECTION_STRING}"
      }
    },
    "StitchMCP": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://stitch.googleapis.com/mcp",
        "--header",
        "X-Goog-Api-Key: {env:GCP_API_KEY}"
      ],
      "enabled": true
    }
  }
}
